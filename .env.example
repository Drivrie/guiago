# Mistral AI API key (free tier at console.mistral.ai — no credit card required)
# When set, all users of the deployed app get AI-powered routes automatically
# without needing to configure anything.
VITE_MISTRAL_KEY=your-mistral-api-key-here

# Google Cloud Translation API key (for translating POI descriptions to app language)
# Required for automatic translation of local-language Wikipedia content
VITE_TRANSLATE_API_KEY=your_google_translate_api_key

# OpenRouteService API key (for step-by-step walking navigation)
# Free tier available at openrouteservice.org
VITE_OPENROUTE_API_KEY=your_openroute_api_key
